# Conexão com o RabbitMQ (obrigatórias)
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=seu_usuario
RABBITMQ_PASSWORD=sua_senha
RABBITMQ_VHOST=/

